# Copy to .env.local and fill in. .env.local is gitignored.

# --- Client-safe (exposed in the browser bundle) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# --- Freemius checkout (client-safe IDs from the Freemius dashboard) ---
VITE_FREEMIUS_PRODUCT_ID=12345
VITE_FREEMIUS_PLAN_MONTHLY=67890            # plan id of the $5/mo plan
VITE_FREEMIUS_PLAN_LIFETIME=67891           # plan id of the $10 lifetime plan

# --- Analytics (client-safe; GA4 is a no-op when this is unset) ---
# VITE_GA4_ID=G-XXXXXXXXXX          # GA4 → Admin → Data Streams → Measurement ID

# --- Build-time (used by the prerender step for canonical/OG URLs) ---
# SITE_URL=https://www.notes2pic.com   # set to your canonical host (Vercel redirects apex→www)

# --- Server-only (set in Vercel dashboard, NEVER commit, NOT VITE_ prefixed) ---
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...            # Supabase → Settings → API → service_role secret
# FREEMIUS_SECRET_KEY=sk_...                  # Freemius → product → Settings → Secret Key (for webhook HMAC)
# LOOPS_API_KEY=...                           # Loops → Settings → API → API key (server-side; welcome-workflow trigger)
# LOOPS_WEBHOOK_SECRET=...                     # Any random string; also set as the Supabase DB Webhook's x-webhook-secret header
