# Copy to .env.local and fill in. .env.local is gitignored.

# --- Client-safe (exposed in the browser bundle) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
VITE_LS_CHECKOUT_MONTHLY=https://YOURSTORE.lemonsqueezy.com/buy/monthly-variant
VITE_LS_CHECKOUT_LIFETIME=https://YOURSTORE.lemonsqueezy.com/buy/lifetime-variant

# --- Build-time (used by the prerender step for canonical/OG URLs) ---
# SITE_URL=https://notes2pics.vercel.app   # optional; Vercel auto-fills from VERCEL_PROJECT_PRODUCTION_URL

# --- Server-only (set in Vercel dashboard, NEVER commit, NOT VITE_ prefixed) ---
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...            # Supabase → Settings → API → service_role secret
# LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-signing-secret
# LEMONSQUEEZY_VARIANT_MONTHLY=123456         # variant id of the $5/mo product
# LEMONSQUEEZY_VARIANT_LIFETIME=123457        # variant id of the $10 lifetime product
